# Runtime mode:
# - static-marketing: static export for marketing site only (default)
# - server-authenticated: enables authenticated app runtime requirements
BILLYBEE_RUNTIME_TARGET=static-marketing

# Canonical application URL for redirects and links.
APP_URL=http://localhost:3000

# Required when BILLYBEE_RUNTIME_TARGET=server-authenticated
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/billybee

# Optional today; expected for local E2E if auth routes are added.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
